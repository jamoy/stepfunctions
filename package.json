{
  "name": "stepfunctions",
  "description": "AWS Step Functions implementation in Node, so you can run your Node.js lambda handlers in your test environments. Made to support Serverless JS testing.",
  "version": "0.2.0",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/jamoy/stepfunctions.git"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "lib",
    "LICENSE",
    "index.js",
    "index.d.ts",
    "package.json"
  ],
  "scripts": {
    "test": "jest",
    "lint": "eslint lib test index.js && prettier --check .",
    "format": "prettier --write .",
    "prepare": "husky || true"
  },
  "dependencies": {
    "asl-validator": "^4.0.0",
    "jsonpath": "^1.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "husky": "^9.1.6",
    "jest": "^30.0.0",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3"
  },
  "peerDependencies": {
    "serverless": ">=1.74.1"
  },
  "peerDependenciesMeta": {
    "serverless": {
      "optional": true
    }
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [
    "aws",
    "step-functions",
    "serverless",
    "asl",
    "test"
  ]
}
